{
  "manifest_version": 3,
  "name": "Grounding",
  "version": "0.1.0"
  "description": "Gates distracting sites behind a typing challenge."
  "content_scripts": [
    {
      "matches": [
        "*//*.youtube.com",
        "*//*.reddit.com",
        "*//*.instagram.com",
        "*//*.x.com",
        "*//*.tiktok.com"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_start"
    }
  ]
}
