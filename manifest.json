{
  "manifest_version": 3,
  "name": "Grounding",
  "version": "0.6.0",
  "description": "A quick and simple extension to try to gate distracting sites behind a calm, distraction-free typing challenge.",
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.reddit.com/*",
        "*://*.instagram.com/*",
        "*://*.x.com/*",
        "*://*.tiktok.com/*",
        "*://*.snapchat.com/*",
        "*://*.facebook.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ]
}
